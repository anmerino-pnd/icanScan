{
  "name": "icanscan-studio",
  "version": "1.0.1",
  "description": "iCanScan Studio - El Escáner y Suite PDF Sketchbook de Alta Calidad",
  "author": "Angel Merino <acedeno00@gmail.com>",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "app": "electron electron/main.cjs",
    "dist": "npm run build && electron-builder --win nsis",
    "build:msix": "npm run build && electron-builder --win appx"
  },
  "build": {
    "appId": "com.docscan.studio",
    "productName": "iCanScan Studio",
    "copyright": "Copyright © 2026 Angel Merino",
    "directories": {
      "output": "dist-app",
      "buildResources": "electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist-backend/icanscan-backend",
        "to": "backend/icanscan-backend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis", "appx"],
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "iCanScan Studio"
    },
    "appx": {
      "identityName": "AngelMerino.iCanScan",
      "publisher": "CN=C630BBC2-C1EA-4A24-A731-3F1F0957A9CB",
      "publisherDisplayName": "Angel Merino",
      "displayName": "iCanScan"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1"
  }
}
